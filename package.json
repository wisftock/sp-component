{
  "name": "sp-component",
  "version": "0.1.0",
  "workspaces": [
    "packages/*"
  ],
  "description": "Librería de Web Components compatible con Angular, React, Vue y cualquier framework",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/wisftock/sp-component.git"
  },
  "homepage": "https://gitlab.com/wisftock/sp-component",
  "bugs": {
    "url": "https://gitlab.com/wisftock/sp-component/-/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./components/*": {
      "import": "./dist/components/*/index.js",
      "types": "./dist/components/*/index.d.ts"
    },
    "./locale/es": {
      "import": "./dist/locale/es.js",
      "types": "./dist/locale/es.d.ts"
    },
    "./locale/en": {
      "import": "./dist/locale/en.js",
      "types": "./dist/locale/en.d.ts"
    },
    "./cdn": "./dist-cdn/sp-component.min.js"
  },
  "files": [
    "dist",
    "dist-cdn",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "vite build",
    "build:cdn": "vite build --config vite.config.cdn.ts",
    "build:cli": "npm run build -w packages/cli",
    "build:all": "npm run build && npm run build:cdn && npm run build:cli",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit --project tsconfig.build.json",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepublishOnly": "npm run type-check && npm run test && npm run build"
  },
  "keywords": [
    "web-components",
    "custom-elements",
    "lit",
    "angular",
    "react",
    "vue",
    "svelte",
    "typescript",
    "components",
    "ui",
    "design-system",
    "i18n",
    "dark-mode",
    "accessible",
    "a11y",
    "storybook"
  ],
  "author": "wisftock",
  "license": "MIT",
  "dependencies": {
    "@floating-ui/dom": "^1.7.6"
  },
  "peerDependencies": {
    "lit": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "lit": { "optional": false }
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.1",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/web-components-vite": "^10.3.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-lit": "^1.15.0",
    "happy-dom": "^20.8.4",
    "prettier": "^3.0.0",
    "storybook": "^10.3.1",
    "terser": "^5.46.1",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  }
}
